<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.LansingFerry" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@color/ferry_blue</item>
        <item name="android:navigationBarColor">@android:color/white</item>
    </style>

    <style name="Theme.LansingFerry.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/ferry_blue</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.LansingFerry</item>
    </style>
</resources>
