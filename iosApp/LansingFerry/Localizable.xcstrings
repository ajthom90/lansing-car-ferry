    "Check the Facebook page regularly for service updates and schedule changes. No Facebook account is needed to view updates." : {
      "comment" : "Facebook notice banner on home screen",
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Consulte la página de Facebook regularmente para actualizaciones del servicio y cambios de horario. No se necesita una cuenta de Facebook para ver las actualizaciones."
          }
        },
        "so" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si joogto ah fiiri bogga Facebook ee cusbooneysiyaha adeegga iyo isbeddelka jadwalka. Looma baahna akoon Facebook si aad u aragto cusbooneysiyaha."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تحقق من صفحة فيسبوك بانتظام للحصول على تحديثات الخدمة وتغييرات الجدول الزمني. لا تحتاج إلى حساب فيسبوك لعرض التحديثات."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Consultez régulièrement la page Facebook pour les mises à jour du service et les changements d'horaire. Aucun compte Facebook n'est nécessaire pour voir les mises à jour."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "请定期查看Facebook页面获取服务更新和时刻表变更。无需Facebook账号即可查看更新。"
          }
        }
      }
    },
